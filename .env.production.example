# Copy to .env.production on the cloud server and fill real values.
# Never commit .env.production.

APP_ENV=production
AUTO_MIGRATE_ON_STARTUP=false
EXPOSE_API_DOCS=false
TRUSTED_PROXY_IPS=["172.28.0.20","172.28.0.10","127.0.0.1"]
POSTGRES_DB=homeai_platform
POSTGRES_USER=homeai
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DB_STARTUP_RETRY_ATTEMPTS=20
DB_STARTUP_RETRY_DELAY_SECONDS=2
REDIS_PASSWORD=replace-with-strong-redis-password

JWT_SECRET_KEY=replace-with-at-least-32-random-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=480
PASSWORD_PBKDF2_ITERATIONS=600000
HASH_EMBEDDING_KEY=replace-with-stable-random-embedding-fallback-key

# Must include the final public origin, otherwise browser POST/PATCH/DELETE is blocked by CSRF middleware.
# Example: ["https://ai.example.com"]
CORS_ORIGINS=["https://your-domain.example.com"]
CORS_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_HEADERS=["Authorization","Content-Type","X-Request-Id"]

# Frontend is served by nginx in the same container network.
VITE_API_BASE=/
VITE_SHOW_DEMO_USERS=false

# Public HTTPS entrypoint handled by Caddy.
CADDY_DOMAIN=your-domain.example.com
CADDY_ADMIN_EMAIL=admin@example.com
HTTP_PORT=80
HTTPS_PORT=443

# Seed users. Use strong one-time initial passwords, then rotate in the UI.
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
SEED_SALES_PASSWORD=replace-with-strong-sales-password
SEED_SALES_DIRECTOR_PASSWORD=replace-with-strong-sales-director-password
SEED_DESIGNER_PASSWORD=replace-with-strong-designer-password
SEED_DESIGN_MANAGER_PASSWORD=replace-with-strong-design-manager-password
SEED_PROMO_PASSWORD=replace-with-strong-promo-password
SEED_PROMO_MANAGER_PASSWORD=replace-with-strong-promo-manager-password
SEED_MANAGEMENT_PASSWORD=replace-with-strong-management-password
SEED_REPAIR_ON_STARTUP=false

AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
AI_REQUEST_TIMEOUT_SECONDS=60
AGENT_INTENT_CLASSIFIER=auto
AGENT_RUNTIME_REQUIRED=true
RAG_GATE_CLASSIFIER=llm
RAG_GATE_MIN_CONFIDENCE=0.55
RAG_GATE_CACHE_TTL_SECONDS=600
RAG_TRIAD_LLM_JUDGE_ENABLED=false

EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_ALLOW_DOWNLOAD=false
HF_ENDPOINT=https://hf-mirror.com
KNOWLEDGE_SEARCH_CACHE_TTL_SECONDS=600
KNOWLEDGE_MAX_UPLOAD_BYTES=104857600
KNOWLEDGE_ASYNC_INDEXING=true
KNOWLEDGE_RECOVER_PENDING_JOBS_ON_STARTUP=true
KNOWLEDGE_RECOVERY_MAX_WORKERS=2
KNOWLEDGE_UPLOAD_STAGING_DIR=/app/uploads/knowledge
MAX_REQUEST_BODY_BYTES=12582912

# WeCom callback / long connection. Enable the profile with:
# docker compose -f docker-compose.prod.yml --profile wecom up -d
WECOM_CALLBACK_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_CORP_ID=
WECOM_ROBOT_WEBHOOK_URL=
WECOM_ROBOT_WEBHOOK_KEY=
WECOM_DEFAULT_CONVERSATION_KEY=sales
WECOM_LONG_CONNECTION_ENABLED=false
WECOM_BOT_ID=
WECOM_BOT_SECRET=
WECOM_LONG_CONNECTION_URL=wss://openws.work.weixin.qq.com
WECOM_INTERNAL_TOKEN=replace-with-random-internal-token-if-wecom-enabled

# Publishing integration
MULTIPOST_API_BASE_URL=https://api.multipost.app
MULTIPOST_API_KEY=
MULTIPOST_TARGET_CLIENT_ID=
MULTIPOST_AUTO_PUBLISH=true

# Video generation. If MoneyPrinterTurbo runs in another container or host, do not use 127.0.0.1.
MONEY_PRINTER_API_BASE_URL=http://moneyprinter:8080/api/v1
MONEY_PRINTER_PROJECT_DIR=
VIDEO_GENERATION_DEFAULT_SOURCE=pexels
VIDEO_GENERATION_DEFAULT_ASPECT=9:16
VIDEO_GENERATION_DEFAULT_CLIP_DURATION=5
VIDEO_GENERATION_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
VIDEO_GENERATION_POLL_INTERVAL_SECONDS=15
VIDEO_GENERATION_POLL_TIMEOUT_SECONDS=900

# Container resource limits. Adjust to fit your server size.
POSTGRES_MEM_LIMIT=1g
POSTGRES_CPUS=1.0
REDIS_MEM_LIMIT=256m
REDIS_CPUS=0.5
BACKEND_MEM_LIMIT=3g
BACKEND_CPUS=2.0
FRONTEND_MEM_LIMIT=256m
FRONTEND_CPUS=0.5
CADDY_MEM_LIMIT=256m
CADDY_CPUS=0.5
WECOM_MEM_LIMIT=256m
WECOM_CPUS=0.5
