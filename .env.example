POSTGRES_DB=homeai_platform
POSTGRES_USER=homeai
POSTGRES_PASSWORD=change-me-in-local-env
DATABASE_URL=postgresql+psycopg://homeai:change-me-in-local-env@localhost:5432/homeai_platform
DB_STARTUP_RETRY_ATTEMPTS=10
DB_STARTUP_RETRY_DELAY_SECONDS=2
APP_ENV=development
AUTO_MIGRATE_ON_STARTUP=true
EXPOSE_API_DOCS=true
TRUSTED_PROXY_IPS=[]
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
PASSWORD_PBKDF2_ITERATIONS=600000
HASH_EMBEDDING_KEY=change-me-if-hash-embedding-fallback-is-used
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]
CORS_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_HEADERS=["Authorization","Content-Type","X-Request-Id"]

# Production must use strong passwords. The values below are local placeholders only.
SEED_ADMIN_PASSWORD=change-me-admin
SEED_SALES_PASSWORD=change-me-sales
SEED_SALES_DIRECTOR_PASSWORD=change-me-salesdir
SEED_DESIGNER_PASSWORD=change-me-designer
SEED_DESIGN_MANAGER_PASSWORD=change-me-designmgr
SEED_PROMO_PASSWORD=change-me-promo
SEED_PROMO_MANAGER_PASSWORD=change-me-promomgr
SEED_MANAGEMENT_PASSWORD=change-me-manage
SEED_REPAIR_ON_STARTUP=false
VITE_DEMO_ADMIN_PASSWORD=change-me-admin
VITE_DEMO_SALES_PASSWORD=change-me-sales
VITE_DEMO_DESIGNER_PASSWORD=change-me-designer
VITE_DEMO_PROMO_PASSWORD=change-me-promo
VITE_SHOW_DEMO_USERS=false

# Optional frontend API base. If unset, the frontend uses window.location.hostname:8000.
# In production, configure this explicitly, for example: https://api.example.com
# VITE_API_BASE=http://127.0.0.1:8000

AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
AI_REQUEST_TIMEOUT_SECONDS=60
AGENT_INTENT_CLASSIFIER=auto
AGENT_RUNTIME_REQUIRED=false
RAG_GATE_CLASSIFIER=llm
RAG_GATE_MIN_CONFIDENCE=0.55
RAG_GATE_CACHE_TTL_SECONDS=600
RAG_TRIAD_LLM_JUDGE_ENABLED=false
REDIS_URL=
KNOWLEDGE_SEARCH_CACHE_TTL_SECONDS=600
KNOWLEDGE_MAX_UPLOAD_BYTES=104857600
KNOWLEDGE_ASYNC_INDEXING=true
KNOWLEDGE_RECOVER_PENDING_JOBS_ON_STARTUP=true
KNOWLEDGE_RECOVERY_MAX_WORKERS=2
KNOWLEDGE_UPLOAD_STAGING_DIR=./uploads/knowledge
MAX_REQUEST_BODY_BYTES=12582912

MULTIPOST_API_BASE_URL=https://api.multipost.app
MULTIPOST_API_KEY=
MULTIPOST_TARGET_CLIENT_ID=
MULTIPOST_AUTO_PUBLISH=true

WECOM_CALLBACK_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_CORP_ID=
WECOM_ROBOT_WEBHOOK_URL=
WECOM_ROBOT_WEBHOOK_KEY=
WECOM_DEFAULT_CONVERSATION_KEY=sales
WECOM_LONG_CONNECTION_ENABLED=false
WECOM_BOT_ID=
WECOM_BOT_SECRET=
WECOM_LONG_CONNECTION_URL=wss://openws.work.weixin.qq.com
WECOM_INTERNAL_TOKEN=

# Video generation via MoneyPrinterTurbo.
MONEY_PRINTER_API_BASE_URL=http://127.0.0.1:8080/api/v1
MONEY_PRINTER_PROJECT_DIR=D:\workplace\MoneyPrinterTurbo
VIDEO_GENERATION_DEFAULT_SOURCE=pexels
VIDEO_GENERATION_DEFAULT_ASPECT=9:16
VIDEO_GENERATION_DEFAULT_CLIP_DURATION=5
VIDEO_GENERATION_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
VIDEO_GENERATION_POLL_INTERVAL_SECONDS=15
VIDEO_GENERATION_POLL_TIMEOUT_SECONDS=900

EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_ALLOW_DOWNLOAD=false
HF_ENDPOINT=https://hf-mirror.com
CHROMA_PERSIST_DIR=./chroma_data
